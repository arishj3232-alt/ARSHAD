# Place .env / .env.local in this directory (artifacts/only-two/), not under src/. Restart Vite after edits.
# firebase-messaging-sw.js is generated on `pnpm dev` / `pnpm build` from these VITE_* variables.
# FCM tokens are stored at Firestore users/{userId} (merge) for Cloud Functions push when the app is closed.

VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
VITE_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
VITE_FIREBASE_VAPID_KEY=your_public_web_push_key
VITE_ROOM_CODE=ArshLovesTanvi

# Optional TURN override (WebRTC relay)
# VITE_TURN_URL=turn:your.turn.server:3478
# VITE_TURN_USERNAME=your_turn_username
# VITE_TURN_CREDENTIAL=your_turn_password
